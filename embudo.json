{
  "data": [
    {
      "id": "datos",
      "label": "Datos del embudo",
      "elements": [
        {
          "id": "stage",
          "label": "Nombre de etapa (opcional)",
          "type": "DIMENSION",
          "options": {
            "min": 0,
            "max": 1
          }
        },
        {
          "id": "count",
          "label": "Valor (inversión en row 1, luego Leads, Visitas, Separación, Venta)",
          "type": "METRIC",
          "options": {
            "min": 1,
            "max": 1
          }
        }
      ]
    }
  ],
  "style": [
    {
      "id": "header",
      "label": "Encabezado",
      "elements": [
        {
          "type": "CHECKBOX",
          "id": "showInvestment",
          "label": "Mostrar línea de inversión",
          "defaultValue": true
        }
      ]
    },
    {
      "id": "names",
      "label": "Nombres de etapas",
      "elements": [
        {
          "type": "TEXTINPUT",
          "id": "stage1Name",
          "label": "Etapa 1",
          "defaultValue": "Leads"
        },
        {
          "type": "TEXTINPUT",
          "id": "stage2Name",
          "label": "Etapa 2",
          "defaultValue": "Visitas"
        },
        {
          "type": "TEXTINPUT",
          "id": "stage3Name",
          "label": "Etapa 3",
          "defaultValue": "Separación"
        },
        {
          "type": "TEXTINPUT",
          "id": "stage4Name",
          "label": "Etapa 4",
          "defaultValue": "Venta"
        }
      ]
    },
    {
      "id": "colors",
      "label": "Colores del embudo (oscuro → claro)",
      "elements": [
        {
          "type": "FILL_COLOR",
          "id": "color1",
          "label": "Etapa 1",
          "defaultValue": {
            "color": "#3d1f7a"
          }
        },
        {
          "type": "FILL_COLOR",
          "id": "color2",
          "label": "Etapa 2",
          "defaultValue": {
            "color": "#7e5cc2"
          }
        },
        {
          "type": "FILL_COLOR",
          "id": "color3",
          "label": "Etapa 3",
          "defaultValue": {
            "color": "#c4b3e0"
          }
        },
        {
          "type": "FILL_COLOR",
          "id": "color4",
          "label": "Etapa 4",
          "defaultValue": {
            "color": "#e8e0f2"
          }
        }
      ]
    },
    {
      "id": "footer",
      "label": "Pie",
      "elements": [
        {
          "type": "TEXTINPUT",
          "id": "footerNote",
          "label": "Nota inferior derecha",
          "defaultValue": "*2 ventas de WEB Directa"
        }
      ]
    }
  ],
  "interactions": []
}